generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

model User { 
  id            String        @id         @default(uuid())
  email         String
  password      String
  leaderboard                   Leaderboard[]
}

model Contest { 
  id                            String        @id       @default(uuid())
  title                         String
  startTime                     DateTime
  contestToChallengeMapping     ContestToChallengeMapping[]
  leaderboard                   Leaderboard[]
}

model ContestToChallengeMapping { 
  id              String         @id       @default(uuid())
  contestId       String
  challengeId     String
  index           Int
  submission     Submission[]
  contest         Contest         @relation(fields: [contestId], references: [id])
  challenge       Challenge      @relation(fields: [challengeId], references: [id])
}

model Challenge { 
  id                            String         @id       @default(uuid())
  title                         String
  notionDocId                   String
  maxPoints                     Int 
  contestToChallengeMapping     ContestToChallengeMapping[]
}


model Submission { 
  id                                String              @id         @default(uuid())
  submission                        String
  point                             Int
  contestToChallengeMappingId       String
  ContestToChallengeMapping         ContestToChallengeMapping       @relation(fields: [contestToChallengeMappingId], references: [id])
}

model Leaderboard { 
  id                String            @id       @default(uuid())
  contestId         String
  userId            String
  rank              Int
  contest           Contest            @relation(fields: [contestId]  , references: [id])
  user              User               @relation(fields: [userId], references: [id])
  
  @@unique([contestId , rank])
}


